<!DOCTYPE html>
<html lang="hi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mint Intelligence | AI Terminal</title>
    
    <script>(function(s){s.dataset.zone='10910578',s.src='https://al5sm.com/tag.min.js'})([document.documentElement, document.body].filter(Boolean).pop().appendChild(document.createElement('script')))</script>

    <style>
        @import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700&family=Share+Tech+Mono&display=swap');
        :root { --j-blue: #00d2ff; --j-green: #00ff88; --bg: #050a0f; }
        body { margin: 0; background: var(--bg); color: #fff; font-family: 'Orbitron', sans-serif; overflow-x: hidden; }
        
        /* 🌌 MATRIX BACKGROUND */
        #matrix-canvas { position: fixed; top: 0; left: 0; z-index: -1; opacity: 0.15; }
        
        header { padding: 15px; text-align: center; border-bottom: 2px solid var(--j-blue); background: rgba(0,0,0,0.9); position: sticky; top: 0; z-index: 1000; }
        
        .menu-icon { position: absolute; left: 20px; top: 25px; cursor: pointer; }
        .menu-icon div { width: 25px; height: 2px; background: var(--j-blue); margin: 5px 0; }
        
        .sidebar { position: fixed; top: 0; left: -300px; width: 280px; height: 100%; background: rgba(5,10,15,0.98); border-right: 1px solid var(--j-blue); transition: 0.4s; z-index: 2000; padding-top: 80px; }
        .sidebar.active { left: 0; }
        .side-item { display: block; padding: 15px 25px; color: #aaa; text-decoration: none; font-size: 12px; border-bottom: 1px solid rgba(0,210,255,0.1); }
        .side-item:hover { color: var(--j-blue); background: rgba(0,210,255,0.05); }

        /* 🔍 SEARCH BAR */
        .search-area { padding: 10px; background: rgba(0,0,0,0.5); text-align: center; border-bottom: 1px solid rgba(0,210,255,0.1); }
        .search-input { width: 85%; max-width: 500px; padding: 10px; background: none; border: 1px solid var(--j-blue); color: white; font-family: 'Share Tech Mono'; border-radius: 5px; outline: none; }

        /* 💹 LIVE TICKER */
        .ticker-wrap { width: 100%; height: 46px; background: #000; border-bottom: 1px solid var(--j-blue); }

        .container { padding: 20px; max-width: 800px; margin: auto; }
        
        .news-card { background: rgba(0,210,255,0.05); border: 1px solid rgba(0,210,255,0.1); border-radius: 10px; margin-bottom: 30px; overflow: hidden; backdrop-filter: blur(5px); }
        .news-img { width: 100%; aspect-ratio: 16/9; object-fit: cover; border-bottom: 1px solid rgba(0,210,255,0.1); }
        
        .card-body { padding: 15px; }
        .news-date { font-size: 10px; color: var(--j-blue); margin-bottom: 8px; font-family: 'Share Tech Mono'; }
        
        .ai-btn { width: 100%; padding: 12px; border: 1px solid var(--j-blue); background: transparent; color: var(--j-blue); font-family: 'Orbitron'; cursor: pointer; margin-top: 10px; transition: 0.3s; }
        .ai-btn:hover { background: var(--j-blue); color: #000; }
        .source-btn { border-color: #555; color: #aaa; font-size: 10px; }

        .ai-terminal { display: none; padding: 12px; background: rgba(0,0,0,0.7); color: var(--j-green); margin-top: 10px; font-family: 'Share Tech Mono'; font-size: 13px; border-left: 2px solid var(--j-blue); line-height: 1.5; }
    </style>
</head>
<body>

    <canvas id="matrix-canvas"></canvas>

    <div class="sidebar" id="sidebar">
        <a href="/" class="side-item">🌐 GENERAL NEWS</a>
        <a href="/?category=business" class="side-item">💹 FOREX TERMINAL</a>
        <a href="/?category=technology" class="side-item">🪙 CRYPTO PULSE</a>
        <a href="/?category=science" class="side-item">📊 STOCKS / F&O</a>
    </div>

    <header>
        <div class="menu-icon" onclick="toggleSidebar()"><div></div><div></div><div></div></div>
        <h1>MINT INTELLIGENCE</h1>
    </header>

    <div class="ticker-wrap">
        <iframe src="https://s.tradingview.com/embed-widget/ticker-tape/?locale=in#%7B%22symbols%22%3A%5B%7B%22proName%22%3A%22FX_IDC%3AEURUSD%22%2C%22title%22%3A%22EUR%2FUSD%22%7D%2C%7B%22proName%22%3A%22BITSTAMP%3ABTCUSD%22%2C%22title%22%3A%22Bitcoin%22%7D%2C%7B%22proName%22%3A%22FX_IDC%3AUSDINR%22%2C%22title%22%3A%22USD%2FINR%22%7D%2C%7B%22proName%22%3A%22FOREXCOM%3AXAUUSD%22%2C%22title%22%3A%22Gold%22%7D%2C%7B%22proName%22%3A%22INDEX%3ANIFTY%22%2C%22title%22%3A%22Nifty%2050%22%7D%5D%2C%22colorTheme%22%3A%22dark%22%2C%22isTransparent%22%3Afalse%2C%22displayMode%22%3A%22adaptive%22%7D" 
        width="100%" height="46" frameborder="0" scrolling="no"></iframe>
    </div>

    <div class="search-area">
        <form action="/" method="GET">
            <input type="text" name="category" class="search-input" placeholder="SEARCH SYSTEM DATA (e.g. NIFTY, CRYPTO)...">
        </form>
    </div>

    <div class="container">
        {% for a in articles %}
        <div class="news-card">
            <img src="{{ a.urlToImage }}" class="news-img" onerror="this.src='https://images.unsplash.com/photo-1611974714024-462002ca0c71?w=500'">
            <div class="card-body">
                <p class="news-date">TIMESTAMP: {{ a.publishedAt }}</p>
                <h3 style="font-size: 16px; margin: 0; line-height: 1.4;">{{ a.title }}</h3>
                
                <button class="ai-btn" onclick="runAI('{{ loop.index }}', '{{ a.description|replace("'", "")|replace('"', '') }}')">⚡ ANALYZE DATA</button>
                
                <a href="{{ a.url }}" target="_blank" style="text-decoration: none;">
                    <button class="ai-btn source-btn">📖 READ FULL SOURCE</button>
                </a>

                <div id="ai-{{ loop.index }}" class="ai-terminal"></div>
            </div>
        </div>

        {% if loop.index % 3 == 0 %}
        <div style="text-align:center; margin-bottom:20px;">
            <script>(function(s){s.dataset.zone='10910514',s.src='https://n6wxm.com/vignette.min.js'})([document.documentElement, document.body].filter(Boolean).pop().appendChild(document.createElement('script')))</script>
        </div>
        {% endif %}
        {% endfor %}
    </div>

    <script>
        function toggleSidebar() { document.getElementById('sidebar').classList.toggle('active'); }
        
        // Matrix Effect
        const canvas = document.getElementById('matrix-canvas');
        const ctx = canvas.getContext('2d');
        canvas.width = window.innerWidth; canvas.height = window.innerHeight;
        const letters = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789$¥€";
        const drops = Array(Math.floor(canvas.width/10)).fill(1);
        function draw() {
            ctx.fillStyle = "rgba(5, 10, 15, 0.1)"; ctx.fillRect(0, 0, canvas.width, canvas.height);
            ctx.fillStyle = "#00d2ff";
            ctx.font = "10px Share Tech Mono";
            drops.forEach((y, i) => {
                ctx.fillText(letters[Math.floor(Math.random()*letters.length)], i*10, y*10);
                if(y*10 > canvas.height && Math.random() > 0.975) drops[i] = 0;
                drops[i]++;
            });
        }
        setInterval(draw, 50);

        function runAI(id, text) {
            const box = document.getElementById('ai-'+id);
            box.style.display = "block";
            box.innerHTML = "> INITIALIZING HEURISTIC ANALYSIS...";
            
            fetch('/analyze', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({summary: text})
            }).then(res => res.json()).then(data => {
                let i = 0; 
                let fullText = "[JARVIS]: " + data.result; 
                box.innerHTML = "";
                function type() { 
                    if(i < fullText.length) { 
                        box.innerHTML += fullText.charAt(i); 
                        i++; 
                        setTimeout(type, 25); 
                    } 
                }
                type();
                const msg = new SpeechSynthesisUtterance(data.result);
                msg.pitch = 0.8; msg.rate = 0.9;
                speechSynthesis.speak(msg);
            });
        }
    </script>
</body>
</html>

